# LLM
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=
EMBEDDING_MODEL=
QDRANT_VECTOR_DIM=

# Qdrant
QDRANT_URL=http://localhost:6333

# Redis (shared with Langfuse — password required)
REDIS_URL=redis://:myredissecret@localhost:6379

# Reranker
RERANKER_ENABLED=true
RERANKER_BACKEND=
RERANKER_URL=
RERANKER_MODEL=
RERANKER_TOP_N=6
RERANKER_CANDIDATES=25

# BM25
BM25_ENABLED=false

# Langfuse (pre-seeded keys from docker-compose)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# Phoenix
PHOENIX_HOST=http://localhost:6006

# App
API_PORT=8000
CHAINLIT_PORT=8080
SQLITE_PATH=data/legal.db
